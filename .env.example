# ============================================
# life-os — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local — already in .gitignore

# Supabase (database + auth)
# Get your project URL and keys from: https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude (AI insights + inbox classification)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# LLM Provider selection: claude | mock (default: mock)
# Use 'mock' for development without an API key
NEXT_PUBLIC_LLM_PROVIDER=mock

# App
NODE_ENV=development
